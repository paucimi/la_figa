# ─── Vertex AI (reemplaza la GEMINI_API_KEY) ────────────────────────────────
# Tu Project ID de Google Cloud (donde tienes los 300€ de crédito)
GOOGLE_CLOUD_PROJECT=tu-project-id

# Región donde está habilitado Vertex AI
GOOGLE_CLOUD_LOCATION=us-central1

# Solo necesario en desarrollo local.
# En Cloud Run NO hace falta: el Service Account adjunto actúa como credencial.
# Opción A: apuntar al JSON descargado de IAM → Cuentas de servicio
# GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/service-account.json
# Opción B: usar gcloud CLI:  gcloud auth application-default login

# ─── Configuración editorial ────────────────────────────────────────────────
NEWSPAPER_NAME=la_figa
GEMINI_MODEL=gemini-2.5-flash
LANGUAGE=español
